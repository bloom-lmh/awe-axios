{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@decoraxios/all": ["./packages/all/src/index.ts"],
      "@decoraxios/core": ["./packages/core/src/index.ts"],
      "@decoraxios/mock": ["./packages/mock/src/index.ts"],
      "@decoraxios/ioc-aop": ["./packages/ioc-aop/src/index.ts"],
      "decoraxios": ["./packages/decoraxios/src/index.ts"],
      "decoraxios/core": ["./packages/decoraxios/src/core.ts"],
      "awe-axios": ["./packages/awe-axios/index.d.ts"],
      "awe-axios/core": ["./packages/awe-axios/core.d.ts"],
      "@decoraxios/awe-axios-core": ["./packages/compat-awe-axios-core/index.d.ts"],
      "@decoraxios/awe-axios-mock": ["./packages/compat-awe-axios-mock/index.d.ts"],
      "@decoraxios/awe-axios-ioc-aop": ["./packages/compat-awe-axios-ioc-aop/index.d.ts"],
      "@decoraxios/awe-axios-all": ["./packages/compat-awe-axios-all/index.d.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": [
    "packages/*/dist/**",
    "packages/*/src/**/__tests__/**",
    "node_modules",
    "docs/.vitepress/dist/**"
  ]
}
