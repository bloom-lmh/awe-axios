{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "noEmit": true,
    "paths": {
      "@awe-axios/all": ["./packages/all/src/index.ts"],
      "@awe-axios/core": ["./packages/core/src/index.ts"],
      "@awe-axios/mock": ["./packages/mock/src/index.ts"],
      "@awe-axios/ioc-aop": ["./packages/ioc-aop/src/index.ts"],
      "awe-axios": ["./packages/awe-axios/src/index.ts"],
      "awe-axios/core": ["./packages/awe-axios/src/core.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": [
    "packages/*/dist/**",
    "packages/*/src/**/__tests__/**",
    "node_modules",
    "docs/.vitepress/dist/**"
  ]
}
