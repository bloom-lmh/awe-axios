{
  "name": "awe-axios-workspace",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b packages/core packages/mock packages/ioc-aop packages/awe-axios",
    "clean": "rimraf packages/*/dist coverage .vitepress-cache",
