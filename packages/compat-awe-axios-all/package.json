  "description": "Compatibility alias for @decoraxios/all",
  "author": "SWUST-LMH <1357526355@qq.com>",
  "license": "MIT",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bloom-lmh/awe-axios.git"
  },
  "homepage": "https://github.com/bloom-lmh/awe-axios#readme",
