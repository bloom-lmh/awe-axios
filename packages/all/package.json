{
  "name": "@decoraxios/all",
  "version": "0.3.0",
  "description": "Full bundle package for Decoraxios",
  "author": "SWUST-LMH <1357526355@qq.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bloom-lmh/awe-axios.git"
  },
  "homepage": "https://github.com/bloom-lmh/awe-axios#readme",
  "bugs": {
    "url": "https://github.com/bloom-lmh/awe-axios/issues"
  },
  "keywords": [
    "axios",
    "mock",
    "ioc",
    "aop",
    "decorator",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "dependencies": {
    "@decoraxios/core": "^0.3.0",
    "@decoraxios/ioc-aop": "^0.3.0",
    "@decoraxios/mock": "^0.3.0"
  },
  "peerDependencies": {
    "axios": "^1.11.0",
    "msw": "^2.11.6",
    "reflect-metadata": "^0.2.2"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts"
  }
}
