{
  "name": "awe-axios",
  "version": "0.3.0",
  "description": "Compatibility alias for decoraxios",
  "author": "SWUST-LMH <1357526355@qq.com>",
  "license": "MIT",
  "type": "module",
  "main": "./index.cjs",
  "module": "./index.js",
  "types": "./index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/bloom-lmh/awe-axios.git"
  },
  "homepage": "https://github.com/bloom-lmh/awe-axios#readme",
  "bugs": {
    "url": "https://github.com/bloom-lmh/awe-axios/issues"
  },
  "keywords": [
    "axios",
    "decorator",
    "http",
    "typescript"
  ],
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    },
    "./core": {
      "types": "./core.d.ts",
      "import": "./core.js",
      "require": "./core.cjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "index.js",
    "index.cjs",
    "index.d.ts",
    "core.js",
    "core.cjs",
    "core.d.ts",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "dependencies": {
    "decoraxios": "^0.3.0"
  },
  "peerDependencies": {
    "axios": "^1.11.0"
  }
}
